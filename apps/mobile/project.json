{
  "name": "mobile",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/mobile/src",
  "projectType": "application",
  "tags": [],
  "targets": {
    "start": {
      "executor": "nx:run-commands",
      "continuous": true,
      "options": {
        "command": "expo start --go --lan",
        "cwd": "apps/mobile"
      }
    },
    "start-tunnel": {
      "executor": "nx:run-commands",
      "continuous": true,
      "options": {
        "command": "expo start --go --tunnel",
        "cwd": "apps/mobile"
      }
    }
  }
}
